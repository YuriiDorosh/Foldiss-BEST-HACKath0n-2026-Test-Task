# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=postgres
POSTGRES_USER=odoo
POSTGRES_PASSWORD=StrongDBPass_123
NGINX_PORT=5433

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ─── Odoo XML-RPC ─────────────────────────────────────────────────────────────
ODOO_URL=http://odoo:8069
ODOO_DB=postgres
ODOO_USER=admin
ODOO_PASSWORD=admin

# ─── Frontend ─────────────────────────────────────────────────────────────────
# VITE_ODOO_URL: empty = same-origin (nginx proxies /uav/* → odoo). Override for dev only.
VITE_ODOO_URL=
# VITE_ODOO_EXTERNAL_URL: public URL of Odoo used for the "Open Odoo" button on the landing page
VITE_ODOO_EXTERNAL_URL=http://localhost:5433

# ─── AI model ─────────────────────────────────────────────────────────────────
HF_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
HF_CACHE_DIR=/app/model_cache
LORA_ADAPTER_PATH=/app/lora_adapter

HF_TOKEN=your_huggingface_token