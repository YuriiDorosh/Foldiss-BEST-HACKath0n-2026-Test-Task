<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Form View ──────────────────────────────────────────────────────── -->
    <record model="ir.ui.view" id="uav_mission_view_form">
        <field name="name">uav.mission.view.form</field>
        <field name="model">uav.mission</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                        name="action_start_parsing"
                        type="object"
                        string="▶ Start Parsing"
                        class="btn-primary"
                        invisible="status != 'draft'"
                    />
                    <button
                        name="action_rerun"
                        type="object"
                        string="↺ Rerun"
                        class="btn-secondary"
                        invisible="status not in ('parsed', 'ai_processing', 'done', 'error')"
                        confirm="This will reset all results and rerun parsing + AI. Continue?"
                    />
                    <button
                        name="action_open_viewer"
                        type="object"
                        string="🌐 Open 3D Viewer"
                        class="btn-secondary"
                        invisible="status not in ('parsed', 'ai_processing', 'done')"
                    />
                    <field
                        name="status"
                        widget="statusbar"
                        statusbar_visible="draft,queued,parsing,parsed,ai_processing,done"
                    />
                </header>

                <sheet>
                    <!-- AI processing banner -->
                    <div
                        invisible="status != 'ai_processing'"
                        class="alert alert-warning text-center mb-3"
                        role="alert"
                    >
                        <strong>AI analysis in progress.</strong>
                        This may take some time depending on server load.
                        You can leave this page — results will appear automatically when ready.
                    </div>

                    <!-- Parsing banner -->
                    <div
                        invisible="status not in ('queued', 'parsing')"
                        class="alert alert-info text-center mb-3"
                        role="alert"
                    >
                        <strong>Flight log is being parsed.</strong>
                        This usually takes a few seconds.
                    </div>

                    <!-- Mission info -->
                    <group>
                        <group string="Mission">
                            <field name="name"/>
                            <field name="log_file" filename="log_filename" widget="binary"/>
                            <field name="log_filename" invisible="1"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                        <group string="Status">
                            <field name="parse_result_id" readonly="1"/>
                            <field
                                name="error_message"
                                readonly="1"
                                invisible="status != 'error'"
                                widget="text"
                            />
                        </group>
                    </group>

                    <!-- Metrics + AI tabs (shown once parsing is done) -->
                    <notebook invisible="not parse_result_id">

                        <page string="Flight Metrics" name="metrics">
                            <group>
                                <group string="Distance &amp; Speed">
                                    <field name="result_total_distance"/>
                                    <field name="result_max_h_speed"/>
                                    <field name="result_max_v_speed"/>
                                    <field name="result_max_acceleration"/>
                                    <field name="result_max_altitude_gain"/>
                                </group>
                                <group string="Time &amp; Sensors">
                                    <field name="result_flight_duration"/>
                                    <field name="result_gps_count"/>
                                    <field name="result_gps_sample_rate"/>
                                    <field name="result_imu_count"/>
                                    <field name="result_imu_sample_rate"/>
                                </group>
                            </group>
                        </page>

                        <page string="AI Analysis" name="ai">
                            <div invisible="not ai_conclusion">
                                <field
                                    name="ai_conclusion"
                                    readonly="1"
                                    widget="text"
                                    nolabel="1"
                                />
                            </div>
                            <div invisible="ai_conclusion">
                                <p class="text-muted">
                                    AI analysis has not been generated yet.
                                    Status: <field name="status" readonly="1"/>
                                </p>
                            </div>
                        </page>

                    </notebook>
                </sheet>

                <!-- Chatter (status history + comments) -->
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── List View ──────────────────────────────────────────────────────── -->
    <record model="ir.ui.view" id="uav_mission_view_list">
        <field name="name">uav.mission.view.list</field>
        <field name="model">uav.mission</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field
                    name="status"
                    widget="badge"
                    decoration-success="status == 'done'"
                    decoration-info="status in ('parsing', 'ai_processing', 'queued')"
                    decoration-warning="status == 'parsed'"
                    decoration-danger="status == 'error'"
                />
                <field name="result_total_distance" optional="show"/>
                <field name="result_max_h_speed"    optional="show"/>
                <field name="result_flight_duration" optional="show"/>
                <field name="user_id"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- ── Window Action ──────────────────────────────────────────────────── -->
    <record model="ir.actions.act_window" id="uav_mission_action">
        <field name="name">UAV Missions</field>
        <field name="res_model">uav.mission</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Upload your first flight log!
            </p>
            <p>
                Create a mission, upload an ArduPilot .BIN file,
                then click <strong>Start Parsing</strong>.
            </p>
        </field>
    </record>

</odoo>
